{
  "name": "svelte-wysiwyg-editor",
  "version": "0.2.1",
  "description": "A dependency-light WYSIWYG rich text editor for Svelte 4 & 5. Built on the native contenteditable + document.execCommand API, with link/image/text bubbles, markdown import, HTML source view, fullscreen, and configurable upload/gallery hooks.",
  "license": "MIT",
  "author": "Maulana Shalihin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maulanashalihin/svelte-wysiwyg-editor.git"
  },
  "homepage": "https://github.com/maulanashalihin/svelte-wysiwyg-editor#readme",
  "bugs": {
    "url": "https://github.com/maulanashalihin/svelte-wysiwyg-editor/issues"
  },
  "keywords": [
    "svelte",
    "wysiwyg",
    "rich-text",
    "editor",
    "contenteditable",
    "svelte-component",
    "svelte-4",
    "svelte-5"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./RichTextEditor.svelte": {
      "types": "./dist/RichTextEditor.svelte.d.ts",
      "svelte": "./dist/RichTextEditor.svelte",
      "default": "./dist/RichTextEditor.svelte"
    },
    "./editor.css": "./dist/editor.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite dev",
    "build:css": "tailwindcss -i src/lib/styles.css -o dist/editor.css --minify",
    "build:preprocess": "node scripts/preprocess-styles.js",
    "build": "svelte-package && npm run build:css && npm run build:preprocess",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "marked": "^14.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@tailwindcss/typography": "^0.5.20",
    "autoprefixer": "^10.5.4",
    "postcss": "^8.5.21",
    "svelte": "^4.2.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
